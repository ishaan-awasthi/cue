# Cue — copy this file to .env and fill in values.
# All variables below are required unless marked optional.

# Supabase (required)
# SUPABASE_URL — project URL from Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY — anon/public API key from Supabase dashboard
SUPABASE_KEY=your-anon-key

# Deepgram (required) — real-time STT, filler word detection, pacing
DEEPGRAM_API_KEY=your-deepgram-key

# ElevenLabs (required) — TTS for nudge and Q&A answer audio delivery
ELEVENLABS_API_KEY=your-elevenlabs-key
# ELEVENLABS_VOICE_ID — the specific voice to use for whispered nudges
ELEVENLABS_VOICE_ID=your-voice-id

# OpenAI (required) — used for text embeddings (text-embedding-3-small) for the RAG pipeline
OPENAI_API_KEY=your-openai-key

# Coaching thresholds (optional — defaults shown)
# NUDGE_INTERVAL_SECONDS — how often coaching engine evaluates signals (default 30)
NUDGE_INTERVAL_SECONDS=30
# ATTENTION_THRESHOLD — audience attention score below which a nudge is triggered (default 0.6)
ATTENTION_THRESHOLD=0.6
# FILLER_WORD_RATE_THRESHOLD — filler words per minute above which a nudge is triggered (default 3)
FILLER_WORD_RATE_THRESHOLD=3

# Fluency model (required for post-session report)
# FLUENCY_MODEL_PATH — local path to the downloaded fluency classifier model file
FLUENCY_MODEL_PATH=./models/fluency-model

# Q&A pipeline (optional — defaults shown)
# QA_MATCH_THRESHOLD — cosine similarity threshold above which speaker response is considered sufficient and answer is NOT whispered (default 0.75)
QA_MATCH_THRESHOLD=0.75
# QA_SILENCE_TIMEOUT_SECONDS — seconds after question ends before answer is whispered regardless of fluency score (default 4)
QA_SILENCE_TIMEOUT_SECONDS=4
