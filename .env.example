# Cue — copy this file to .env and fill in values.
# All variables below are required unless marked optional.

# Supabase (required)
# SUPABASE_URL — project URL from Supabase dashboard (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY — Secret key from Supabase dashboard (Settings → API → Secret key)
# Use the Secret key here (not Publishable) — the backend needs full DB access
SUPABASE_KEY=your-secret-key

# Deepgram (required) — real-time STT, filler word detection, pacing
DEEPGRAM_API_KEY=your-deepgram-key

# Deepgram TTS (optional — defaults shown)
# DEEPGRAM_TTS_MODEL — voice model (see deepgram.com/docs/aura for all voices)
# DEEPGRAM_TTS_MODEL=aura-asteria-en
# TTS_TIMEOUT_SECONDS — per-request timeout for Deepgram TTS calls (default 10)
# TTS_TIMEOUT_SECONDS=10
# TTS_MAX_RETRIES — number of retries on TTS failure (default 2)
# TTS_MAX_RETRIES=2

# OpenAI (required) — embeddings (text-embedding-3-small), Q&A answers (gpt-4o-mini), reports (gpt-4o)
OPENAI_API_KEY=your-openai-key

# Coaching thresholds (optional — defaults shown)
# NUDGE_INTERVAL_SECONDS — how often coaching engine evaluates signals (default 30)
NUDGE_INTERVAL_SECONDS=30
# ATTENTION_THRESHOLD — audience attention score below which a nudge is triggered (default 0.6)
ATTENTION_THRESHOLD=0.6
# FILLER_WORD_RATE_THRESHOLD — filler words per minute above which a nudge is triggered (default 3)
FILLER_WORD_RATE_THRESHOLD=3

# Fluency model (required for post-session report)
# FLUENCY_MODEL_PATH — local path to the downloaded fluency classifier model file
FLUENCY_MODEL_PATH=./models/fluency-model

# Q&A pipeline (optional — defaults shown)
# QA_MATCH_THRESHOLD — cosine similarity threshold above which speaker response is considered sufficient and answer is NOT whispered (default 0.75)
QA_MATCH_THRESHOLD=0.75
# QA_SILENCE_TIMEOUT_SECONDS — seconds after question ends before answer is whispered regardless of fluency score (default 4)
QA_SILENCE_TIMEOUT_SECONDS=4
# QUESTION_CAPTURE_WINDOW_SECONDS — seconds to buffer question chunks before firing RAG (default 3.0)
QUESTION_CAPTURE_WINDOW_SECONDS=3.0
# QA_MIN_CHUNK_SIMILARITY — chunks below this similarity are rejected; GPT fallback used (default 0.35)
QA_MIN_CHUNK_SIMILARITY=0.35

# Optional — chat completions (Anthropic takes priority over OpenRouter/OpenAI)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-v1-...

RESEND_API_KEY=re_

SUPABASE_SERVICE_ROLE_KEY=eyJ
